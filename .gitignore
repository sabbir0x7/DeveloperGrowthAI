# ============================================================
# DevGrowth AI — root .gitignore
# ============================================================

# --- Secrets (NEVER commit these) ---
backend/.env
backend/.env.*
!backend/.env.example
**/.env
**/.env.*
!**/.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
ENV/
build/
dist/
*.egg
*.egg-info/
.eggs/
.pytest_cache/
.hypothesis/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- Flutter / Dart ---
frontend/.dart_tool/
frontend/build/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages
frontend/pubspec.lock
*.iml
*.ipr
*.iws
.idea/
.gradle/
local.properties
GeneratedPluginRegistrant.java
frontend/android/.gradle/
frontend/android/local.properties
frontend/android/app/debug/
frontend/android/app/profile/
frontend/android/app/release/
frontend/ios/.symlinks/
frontend/ios/Flutter/App.framework
frontend/ios/Flutter/Flutter.framework
frontend/ios/Flutter/Flutter.podspec
frontend/ios/Flutter/Generated.xcconfig
frontend/ios/Flutter/app.flx
frontend/ios/Flutter/app.zip
frontend/ios/Flutter/flutter_assets/
frontend/ios/ServiceDefinitions.json
frontend/ios/Runner/GeneratedPluginRegistrant.*
frontend/ios/Pods/

# --- Kiro spec (optional — keep if you want spec in repo) ---
# .kiro/

# --- OS ---
.DS_Store
Thumbs.db
*.swp
*.swo

# --- Editor ---
.vscode/
*.code-workspace
