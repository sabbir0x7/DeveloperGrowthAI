# DevGrowth AI backend environment variables.
# Copy this file to `.env` and fill in real values for local development.
# Never commit `.env` — it is gitignored.

# Supabase project URL, e.g. https://abcd1234.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service-role key. Server-side only. Bypasses RLS, so never ship to
# the Flutter app. Rotate immediately if leaked.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# HS256 secret used to sign Supabase-issued JWTs. Pulled from
# Supabase project settings → API → JWT Settings → JWT Secret.
SUPABASE_JWT_SECRET=replace-with-jwt-secret

# Comma-separated Fernet keys, NEWEST FIRST. Each key must be a 32-byte
# url-safe base64-encoded value. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# To rotate: prepend a new key and keep older keys until all ciphertexts are
# re-encrypted.
FERNET_KEYS=replace-with-primary-fernet-key,optional-previous-key

# Default model identifier used when a user has not overridden it.
AI_MODEL_DEFAULT=gpt-4o-mini

# Default OpenAI-compatible base URL. Must be HTTPS.
AI_PROVIDER_BASE_URL_DEFAULT=https://api.openai.com/v1
